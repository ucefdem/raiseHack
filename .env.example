# Shared Meet room (one link for every agent in the office)
# All apps (worker speech loop, backend, apps/api, apps/web) resolve this first.
SHARED_MEET_URL=https://meet.google.com/lookup/raisehack-office
NEXT_PUBLIC_SHARED_MEET_URL=https://meet.google.com/lookup/raisehack-office

# Cursor Cloud Agents API — used by the voice loop as a tool call
# https://cursor.com/docs/cloud-agent/api/endpoints
CURSOR_API_KEY=
CURSOR_AGENTS_API_URL=https://api.cursor.com/v1/agents
CURSOR_AGENTS_MODEL=composer-2
CURSOR_AGENTS_REPOSITORY=https://github.com/ucefdem/raiseHack
CURSOR_AGENTS_REF=main

# Web app (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API (apps/api)
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/raisehack
OPENAI_API_KEY=
CORS_ORIGIN=http://localhost:3000
