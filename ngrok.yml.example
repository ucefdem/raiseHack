version: "3"
agent:
  authtoken: YOUR_NGROK_AUTHTOKEN
tunnels:
  web:
    addr: 3000
    proto: http
    # Reserved domain (if your plan has one):
    # domain: surviving-cane-steering.ngrok-free.dev
  backend:
    addr: 8000
    proto: http
    # Second reserved domain, or omit for a random *.ngrok-free.dev URL
