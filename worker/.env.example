# Backend (worker WebSocket)
BACKEND_WS_URL=ws://localhost:8000/worker

# If worker runs on another machine, use the backend ngrok URL (wss, not ws):
# BACKEND_WS_URL=wss://YOUR-BACKEND-TUNNEL.ngrok-free.dev/worker
WORKER_ID=worker_1

# Gradium speech (STT + TTS + agent routing via speech/)
GRADIUM_API_KEY=gd_your_key_here
VOICE_ID=YTpq7expH9539ERJ
LANGUAGE=en
BUZZWORDS=Angie,Nikki,Olaf
ROUTER_MODE=heuristic
SPEECH_EDITOR_MODE=local

# Shared Meet room for every agent (worker, olaf, apps/api all read this)
SHARED_MEET_URL=https://meet.google.com/lookup/raisehack-office

# Cursor Cloud Agents API — voice-loop tool call (docs.cursor.com/cloud-agent/api)
CURSOR_API_KEY=
CURSOR_AGENTS_API_URL=https://api.cursor.com/v1/agents
CURSOR_AGENTS_MODEL=composer-2.5
CURSOR_AGENT_POLL_TIMEOUT_S=90
CURSOR_AGENTS_REPOSITORY=https://github.com/sokolegg/raiseHack
CURSOR_AGENTS_REF=main
OLAF_MODE=stub

# Local mock incident codebase (no remote repo — Nikki reads these files)
MOCK_INCIDENT_ROOT=
STT_SAMPLE_RATE=24000
STT_FINAL_SILENCE_S=2.5
AGENT_INVOKE_DELAY_S=0.5
STT_TRIGGER_SILENCE_S=1.0
# Set to 0 to wait for [final] transcripts only (fewer false triggers while testing)
STT_PARTIAL_TRIGGER=0
# Angie hold ack: fixed line → TTS immediately on direct call; router runs in parallel
# ANGIE_INSTANT_MODE=hold | local | cloud | off
ANGIE_INSTANT_MODE=hold
ANGIE_INVOKE_DELAY_S=0
ANGIE_HOLD_ACK_TEXT=I'm processing your request right now.
# Legacy toggle — if 0, disables instant ack regardless of ANGIE_INSTANT_MODE
INSTANT_ANGIE_ACK=1

# Audio devices — macOS (BlackHole); see docs/AUDIO_SETUP.md
# brew install blackhole-2ch, then:
CAPTURE_DEVICE="BlackHole 2ch"
PLAYBACK_DEVICE="BlackHole 2ch"
# Linux (PipeWire) example:
# CAPTURE_DEVICE=meet_out.monitor
# PLAYBACK_DEVICE=agent_mic

# Chrome / Playwright
CHROME_USER_DATA_DIR=~/.meeting-agent/chrome-profile
CHROME_CHANNEL=chrome
HEADLESS=false
