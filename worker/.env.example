# Backend
BACKEND_WS_URL=ws://localhost:8000/worker
WORKER_ID=worker_1

# Gemini Live
# Run `uv run python list_models.py` to see Live models your key supports.
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash-native-audio-latest
GEMINI_VOICE=Puck
# Leave empty to use the SDK default (v1beta). Only set GEMINI_API_VERSION=v1alpha
# together with GEMINI_PROACTIVE_AUDIO=true (proactive audio is v1alpha-only).
GEMINI_API_VERSION=
GEMINI_PROACTIVE_AUDIO=false

# Agent identity
AGENT_DISPLAY_NAME=AI Project Agent

# Audio devices (see docs/AUDIO_SETUP.md; run `python verify_audio.py devices`)
# Linux example:
CAPTURE_DEVICE=meet_out.monitor
PLAYBACK_DEVICE=agent_mic
# macOS example:
# CAPTURE_DEVICE=BlackHole
# PLAYBACK_DEVICE=BlackHole

# Chrome / Playwright
CHROME_USER_DATA_DIR=~/.meeting-agent/chrome-profile
CHROME_CHANNEL=chrome
HEADLESS=false

